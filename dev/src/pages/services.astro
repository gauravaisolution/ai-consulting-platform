---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import ServiceIcon from "../components/ServiceIcon.astro";
import { services } from "../site.config";
---

<BaseLayout
  title="Services"
  description="Business websites, AI chatbots, data extraction, knowledge search, and GenAI implementation."
>
  <section class="px-6 py-20">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Our Services</h1>
      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
        From websites and chatbots to data pipelines and AI — we design and deploy the full stack.
      </p>
    </div>
  </section>

  <section class="px-6 pb-20">
    <div class="mx-auto max-w-4xl space-y-8">
      {
        services.map((service, i) => (
          <div class="glass-card hover-lift flex gap-6 rounded-2xl p-8">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400">
              <ServiceIcon name={service.icon} class="h-7 w-7" />
            </div>
            <div>
              <p class="text-sm font-semibold text-blue-600 dark:text-blue-400">
                Service {i + 1}
              </p>
              <h2 class="mt-1 text-2xl font-bold">{service.title}</h2>
              <p class="mt-3 leading-relaxed text-gray-600 dark:text-gray-400">
                {service.description}
              </p>
              <ul class="mt-4 space-y-2 text-sm text-gray-600 dark:text-gray-400">
                {service.details.map((item) => (
                  <li>• {item}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <CTA heading="Not sure which service fits?" subtext="We'll diagnose your needs on a free strategy call." />
</BaseLayout>
