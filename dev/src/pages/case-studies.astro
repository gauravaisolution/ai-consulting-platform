---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import Testimonials from "../components/Testimonials.astro";
import { caseStudies } from "../site.config";
---

<BaseLayout title="Case Studies" description="Real-world project outcomes — websites, chatbots, and data AI.">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-4xl text-center">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Case Studies</h1>
      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
        Measurable outcomes from websites, chatbots, and data systems we've delivered.
      </p>
    </div>
  </section>

  <section class="px-6 pb-12">
    <div class="mx-auto max-w-4xl space-y-8">
      {
        caseStudies.map((study, i) => (
          <article class="glass-card hover-lift reveal rounded-2xl p-8" style={`transition-delay: ${i * 80}ms`}>
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="flex flex-wrap gap-2">
                {study.tags.map((tag) => (
                  <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700 dark:bg-blue-900/50 dark:text-blue-300">
                    {tag}
                  </span>
                ))}
              </div>
              <span class="rounded-lg bg-green-100 px-3 py-1 text-xs font-semibold text-green-700 dark:bg-green-900/40 dark:text-green-300">
                Delivered ✓
              </span>
            </div>
            <h2 class="mt-4 text-2xl font-bold">{study.title}</h2>
            <p class="mt-1 text-sm font-medium text-gray-500">{study.client}</p>
            <p class="mt-4 leading-relaxed text-gray-600 dark:text-gray-400">{study.result}</p>
          </article>
        ))
      }
    </div>
  </section>

  <Testimonials />
  <CTA heading="Want results like these?" subtext="Let's discuss your project on a free strategy call." />
</BaseLayout>
