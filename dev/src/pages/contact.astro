---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../site.config";
---

<BaseLayout
  title="Book a Call"
  description="Schedule a free strategy call or submit a project inquiry."
>
  <section class="px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">Let's talk</h1>
      <p class="mt-6 text-lg text-gray-600 dark:text-gray-400">
        Tell us about your project, then pick a time that works. We'll come prepared with ideas.
      </p>
    </div>
  </section>

  <!-- Step 1: Lead intake (Tally.so) -->
  <section class="px-6 pb-12" id="intake-form">
    <div class="mx-auto max-w-2xl">
      <div class="mb-6 flex items-center gap-3">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white"
          >1</span
        >
        <h2 class="text-xl font-semibold">Project intake</h2>
      </div>
      <div
        class="overflow-hidden rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900"
      >
        <!-- Replace tallyFormUrl in src/site.config.ts with your real Tally embed URL -->
        <iframe
          data-tally-src={site.tallyFormUrl}
          loading="lazy"
          width="100%"
          height="400"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Project intake form"
          class="min-h-[400px] w-full"></iframe>
      </div>
      <p class="mt-3 text-center text-xs text-gray-500">
        Powered by Tally.so — update embed URL in <code class="text-blue-600">src/site.config.ts</code>
      </p>
    </div>
  </section>

  <!-- Step 2: Calendar booking (Cal.com) -->
  <section class="px-6 pb-20" id="calendar">
    <div class="mx-auto max-w-3xl">
      <div class="mb-6 flex items-center gap-3">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white"
          >2</span
        >
        <h2 class="text-xl font-semibold">Schedule your call</h2>
      </div>
      <div
        class="overflow-hidden rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-gray-900"
      >
        <!-- Replace calcomUrl in src/site.config.ts with your real Cal.com embed URL -->
        <iframe
          src={site.calcomUrl}
          width="100%"
          height="700"
          frameborder="0"
          title="Book a strategy call"
          class="min-h-[700px] w-full"></iframe>
      </div>
      <p class="mt-3 text-center text-xs text-gray-500">
        Powered by Cal.com — update embed URL in <code class="text-blue-600">src/site.config.ts</code>
      </p>
    </div>
  </section>
</BaseLayout>

<script
  is:inline
  src="https://tally.so/widgets/embed.js"
></script>
<script is:inline>
  // Tally embed loader
  document.addEventListener("DOMContentLoaded", () => {
    if (typeof Tally !== "undefined") {
      Tally.loadEmbeds();
    }
  });
</script>
