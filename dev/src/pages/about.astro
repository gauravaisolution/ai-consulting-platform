---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import FounderSection from "../components/FounderSection.astro";
import ProcessSection from "../components/ProcessSection.astro";
import TechStack from "../components/TechStack.astro";
import { site } from "../site.config";
---

<BaseLayout title="About" description="About our Data & AI consultancy.">
  <section class="px-6 py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">About {site.name}</h1>
      <p class="mt-6 text-lg leading-relaxed text-gray-600 dark:text-gray-400">
        We're a specialized consultancy helping businesses build their digital presence and automate
        with AI. We ship websites, chatbots, data pipelines, and GenAI integrations — no buzzword
        decks, just working systems.
      </p>
    </div>
  </section>

  <FounderSection />

  <section class="reveal px-6 pb-20">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-center text-2xl font-bold">Our values</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-3">
        <div class="glass-card hover-lift rounded-2xl p-6 text-center">
          <p class="text-2xl">⚡</p>
          <h3 class="mt-3 font-semibold">Ship fast</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Working prototypes in days, not months.
          </p>
        </div>
        <div class="glass-card hover-lift rounded-2xl p-6 text-center">
          <p class="text-2xl">🎯</p>
          <h3 class="mt-3 font-semibold">Results first</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Every feature drives a business outcome.
          </p>
        </div>
        <div class="glass-card hover-lift rounded-2xl p-6 text-center">
          <p class="text-2xl">🔒</p>
          <h3 class="mt-3 font-semibold">No lock-in</h3>
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">
            Open stack, documented handoff, you own the code.
          </p>
        </div>
      </div>
    </div>
  </section>

  <ProcessSection />
  <TechStack />
  <CTA />
</BaseLayout>
