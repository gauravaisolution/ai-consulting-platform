<section class="py-4" id="demo-search">
  <div>
    <div class="mb-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-indigo-600 dark:text-indigo-400">
        Live Demo B
      </p>
      <h2 class="mt-2 text-3xl font-bold">Enterprise Knowledge Search</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        Search across company policies and internal docs — powered by RAG.
      </p>
    </div>

    <div
      class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900"
    >
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          data-query="parental-leave"
          class="search-preset rounded-lg bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-200 dark:bg-indigo-900/50 dark:text-indigo-300 dark:hover:bg-indigo-900"
        >
          Review our parental leave parameters
        </button>
        <button
          type="button"
          data-query="expense-policy"
          class="search-preset rounded-lg bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-200 dark:bg-indigo-900/50 dark:text-indigo-300 dark:hover:bg-indigo-900"
        >
          What is the expense reimbursement policy?
        </button>
        <button
          type="button"
          data-query="data-retention"
          class="search-preset rounded-lg bg-indigo-100 px-4 py-2 text-sm font-medium text-indigo-700 transition hover:bg-indigo-200 dark:bg-indigo-900/50 dark:text-indigo-300 dark:hover:bg-indigo-900"
        >
          How long do we retain customer data?
        </button>
      </div>

      <div class="mt-6">
        <label for="search-input" class="sr-only">Search query</label>
        <input
          id="search-input"
          type="text"
          placeholder="Or type a custom query..."
          class="w-full rounded-xl border border-gray-300 bg-gray-50 px-4 py-3 text-sm outline-none focus:border-indigo-500 focus:ring-2 focus:ring-indigo-500/20 dark:border-gray-700 dark:bg-gray-800"
        />
      </div>

      <div
        id="search-output"
        class="mt-6 min-h-[120px] rounded-xl bg-gray-950 p-6 text-sm leading-relaxed text-gray-300"
      >
        <span class="text-gray-500">Select a preset query or type your own...</span>
      </div>

      <div
        id="search-locked"
        class="mt-4 hidden rounded-xl border border-amber-300 bg-amber-50 p-4 dark:border-amber-700 dark:bg-amber-900/30"
      >
        <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
          Custom search queries are locked for public sandboxes.
        </p>
        <p class="mt-1 text-sm text-amber-700 dark:text-amber-300">
          Book a live strategy session below to hook this framework into your company data.
        </p>
        <a
          href="/contact"
          class="mt-3 inline-block text-sm font-semibold text-amber-900 underline dark:text-amber-100"
        >
          Book a strategy call →
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const ANSWERS: Record<string, string> = {
    "parental-leave":
      "Parental Leave Policy (effective Jan 2026):\n\n• Primary caregivers: 16 weeks fully paid leave\n• Secondary caregivers: 8 weeks fully paid leave\n• Must be taken within 12 months of birth or adoption\n• Flexible return: option for 2-week phased return at 50% schedule\n• Benefits continue throughout leave period\n\nSource: HR Policy Handbook, Section 4.2 — Parental Benefits",
    "expense-policy":
      "Expense Reimbursement Policy:\n\n• Submit expenses within 30 days of incurring\n• Receipts required for all items over $25\n• Travel: economy class for flights under 6 hours\n• Meals: up to $75/day for business travel\n• Pre-approval required for expenses over $500\n• Reimbursement processed within 10 business days via payroll\n\nSource: Finance Policy Manual, Section 7 — Employee Expenses",
    "data-retention":
      "Customer Data Retention Policy:\n\n• Active accounts: data retained for duration of relationship + 90 days\n• Closed accounts: personal data deleted within 30 days\n• Anonymized analytics: retained up to 24 months\n• Legal holds: data preserved as required by litigation\n• Backups purged on rolling 90-day cycle\n• GDPR/CCPA deletion requests honored within 30 days\n\nSource: Data Governance Policy, Section 3 — Retention Schedules",
  };

  const QUERY_MAP: Record<string, string> = {
    "parental-leave": "Review our parental leave parameters",
    "expense-policy": "What is the expense reimbursement policy?",
    "data-retention": "How long do we retain customer data?",
  };

  const output = document.getElementById("search-output")!;
  const locked = document.getElementById("search-locked")!;
  const input = document.getElementById("search-input") as HTMLInputElement;
  let typeInterval: ReturnType<typeof setInterval> | null = null;

  function typeWriter(text: string, element: HTMLElement, speed = 18) {
    if (typeInterval) clearInterval(typeInterval);
    element.textContent = "";
    let i = 0;
    typeInterval = setInterval(() => {
      if (i < text.length) {
        element.textContent += text[i++];
      } else if (typeInterval) {
        clearInterval(typeInterval);
        typeInterval = null;
      }
    }, speed);
  }

  function runPreset(key: string) {
    locked.classList.add("hidden");
    input.value = QUERY_MAP[key] || "";
    typeWriter(ANSWERS[key] || "No results found.", output);
  }

  document.querySelectorAll(".search-preset").forEach((btn) => {
    btn.addEventListener("click", () => {
      const key = (btn as HTMLElement).dataset.query!;
      runPreset(key);
    });
  });

  input?.addEventListener("keydown", (e) => {
    if (e.key !== "Enter") return;
    e.preventDefault();
    const query = input.value.trim().toLowerCase();
    locked.classList.remove("hidden");
    output.innerHTML =
      '<span class="text-gray-500">Custom queries require a connected knowledge base...</span>';
  });
</script>
