---
interface Props {
  name: "globe" | "message-circle" | "file-json" | "search" | "sparkles";
  class?: string;
}

const { name, class: className = "h-6 w-6" } = Astro.props;
const attrs = {
  xmlns: "http://www.w3.org/2000/svg",
  viewBox: "0 0 24 24",
  fill: "none",
  stroke: "currentColor",
  "stroke-width": "1.75",
  "stroke-linecap": "round",
  "stroke-linejoin": "round",
  class: className,
};
---

{
  name === "globe" && (
