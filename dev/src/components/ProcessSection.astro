---
import { processSteps } from "../site.config";
---

<section class="reveal px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400">
        How it works
      </p>
      <h2 class="mt-2 text-3xl font-bold md:text-4xl">From idea to live in 3 steps</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-gray-400">
        No endless meetings. No vague proposals. Just a clear path from discovery to deployment.
      </p>
    </div>

    <div class="relative mt-14 grid gap-8 md:grid-cols-3">
      <!-- Connector line (desktop) -->
      <div
        class="pointer-events-none absolute top-12 right-[16.67%] left-[16.67%] hidden h-0.5 bg-gradient-to-r from-blue-200 via-indigo-200 to-violet-200 md:block dark:from-blue-900 dark:via-indigo-900 dark:to-violet-900"
      >
      </div>

      {
        processSteps.map((step) => (
          <div class="relative text-center">
            <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-600 text-2xl font-bold text-white shadow-lg shadow-blue-600/20">
              {step.step}
            </div>
            <h3 class="mt-6 text-xl font-semibold">{step.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
