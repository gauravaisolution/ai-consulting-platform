---
import { testimonials } from "../site.config";
---

<section class="reveal px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400">
        Client Stories
      </p>
      <h2 class="mt-2 text-3xl font-bold md:text-4xl">What our clients say</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-gray-400">
        Real outcomes from websites, chatbots, and data systems we've delivered.
      </p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <article class="glass-card hover-lift flex flex-col rounded-2xl p-8">
            <!-- Stars -->
            <div class="flex gap-0.5" aria-label={`${t.rating} out of 5 stars`}>
              {Array.from({ length: t.rating }).map(() => (
                <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <span class="mt-4 inline-block w-fit rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700 dark:bg-blue-900/50 dark:text-blue-300">
              {t.service}
            </span>

            <blockquote class="mt-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
              "{t.quote}"
            </blockquote>

            <div class="mt-6 flex items-center gap-3 border-t border-gray-100 pt-6 dark:border-gray-800">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 text-sm font-bold text-white">
                {t.initials}
              </div>
              <div>
                <p class="text-sm font-semibold">{t.name}</p>
                <p class="text-xs text-gray-500">
                  {t.role}, {t.company}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
