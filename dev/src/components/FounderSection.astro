---
import { site } from "../site.config";
---

<section class="reveal px-6 py-16">
  <div class="mx-auto max-w-4xl">
    <div class="glass-card overflow-hidden rounded-3xl p-8 md:p-12">
      <div class="flex flex-col items-center gap-8 md:flex-row md:gap-12">
        <!-- Avatar -->
        <div class="shrink-0">
          <div
            class="flex h-28 w-28 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-600 text-3xl font-bold text-white shadow-xl shadow-blue-600/20"
          >
            FS
          </div>
        </div>
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400">
            Meet the team
          </p>
          <h2 class="mt-2 text-2xl font-bold md:text-3xl">Built by practitioners, not agencies</h2>
          <p class="mt-4 leading-relaxed text-gray-600 dark:text-gray-400">
            {site.name} is a hands-on consultancy — you work directly with the people who design,
            build, and deploy your systems. No account managers, no handoffs. From the first call to
            the final deploy, you get senior-level expertise on every project.
          </p>
          <div class="mt-6 flex flex-wrap gap-4">
            <div class="rounded-xl bg-blue-50 px-4 py-2 dark:bg-blue-950/40">
              <p class="text-lg font-bold text-blue-600">15+</p>
              <p class="text-xs text-gray-500">Projects delivered</p>
            </div>
            <div class="rounded-xl bg-blue-50 px-4 py-2 dark:bg-blue-950/40">
              <p class="text-lg font-bold text-blue-600">5 days</p>
              <p class="text-xs text-gray-500">Avg. website delivery</p>
            </div>
            <div class="rounded-xl bg-blue-50 px-4 py-2 dark:bg-blue-950/40">
              <p class="text-lg font-bold text-blue-600">100%</p>
              <p class="text-xs text-gray-500">Client satisfaction</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
