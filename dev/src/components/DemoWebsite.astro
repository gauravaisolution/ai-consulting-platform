<section class="py-4" id="demo-website">
  <div>
    <div class="mb-6 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-600 dark:text-emerald-400">
        Live Demo C
      </p>
      <h2 class="mt-2 text-3xl font-bold">Business Website Builder</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        Pick an industry — watch us generate a production-ready website preview in seconds.
      </p>
    </div>

    <div
      class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900"
    >
      <p class="mb-3 text-sm font-medium text-gray-700 dark:text-gray-300">Select business type:</p>
      <div class="flex flex-wrap gap-2">
        <button
          type="button"
          data-industry="consulting"
          class="industry-btn rounded-lg bg-emerald-100 px-4 py-2 text-sm font-medium text-emerald-800 transition hover:bg-emerald-200 dark:bg-emerald-900/50 dark:text-emerald-200 dark:hover:bg-emerald-900"
        >
          Consulting
        </button>
        <button
          type="button"
          data-industry="restaurant"
          class="industry-btn rounded-lg bg-emerald-100 px-4 py-2 text-sm font-medium text-emerald-800 transition hover:bg-emerald-200 dark:bg-emerald-900/50 dark:text-emerald-200 dark:hover:bg-emerald-900"
        >
          Restaurant
        </button>
        <button
          type="button"
          data-industry="saas"
          class="industry-btn rounded-lg bg-emerald-100 px-4 py-2 text-sm font-medium text-emerald-800 transition hover:bg-emerald-200 dark:bg-emerald-900/50 dark:text-emerald-200 dark:hover:bg-emerald-900"
        >
          SaaS Startup
        </button>
        <button
          type="button"
          data-industry="retail"
          class="industry-btn rounded-lg bg-emerald-100 px-4 py-2 text-sm font-medium text-emerald-800 transition hover:bg-emerald-200 dark:bg-emerald-900/50 dark:text-emerald-200 dark:hover:bg-emerald-900"
        >
          Retail / E-commerce
        </button>
      </div>

      <button
        id="generate-website"
        type="button"
        disabled
        class="mt-6 w-full rounded-xl bg-emerald-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-emerald-700 disabled:cursor-not-allowed disabled:opacity-40"
      >
        Generate Website Preview
      </button>

      <div id="website-loader" class="mt-6 hidden text-center">
        <div
          class="mx-auto h-10 w-10 animate-spin-slow rounded-full border-4 border-emerald-200 border-t-emerald-600"
        >
        </div>
        <p class="mt-4 text-sm font-medium text-gray-600 dark:text-gray-400">
          Building layout, pages, and booking flow...
        </p>
      </div>

      <div id="website-preview-wrap" class="mt-6 hidden">
        <p class="mb-3 text-sm font-semibold text-emerald-600 dark:text-emerald-400">
          ✓ Website preview ready
        </p>
        <div class="overflow-hidden rounded-xl border border-gray-300 dark:border-gray-700">
          <div class="flex items-center gap-2 bg-gray-200 px-4 py-2 dark:bg-gray-800">
            <span class="h-3 w-3 rounded-full bg-red-400"></span>
            <span class="h-3 w-3 rounded-full bg-yellow-400"></span>
            <span class="h-3 w-3 rounded-full bg-green-400"></span>
            <span
              id="website-url"
              class="ml-3 flex-1 rounded bg-white px-3 py-1 text-xs text-gray-500 dark:bg-gray-900"
            ></span>
          </div>
          <div id="website-preview" class="bg-white p-6 dark:bg-gray-950"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const PREVIEWS: Record<string, { url: string; html: string }> = {
    consulting: {
      url: "https://acme-advisory.com",
      html: `
        <div style="font-family:system-ui,sans-serif">
          <div style="background:linear-gradient(135deg,#059669,#047857);color:white;padding:24px;border-radius:12px;text-align:center">
            <p style="font-size:11px;opacity:0.8;margin:0 0 8px">STRATEGY & ADVISORY</p>
            <h3 style="font-size:22px;font-weight:800;margin:0">Acme Advisory Group</h3>
            <p style="font-size:13px;margin:12px 0 0;opacity:0.9">Expert guidance for growing businesses</p>
            <button style="margin-top:16px;background:white;color:#047857;border:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:13px">Book Free Consultation</button>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:16px">
            <div style="border:1px solid #e5e7eb;border-radius:8px;padding:12px;text-align:center"><p style="font-size:20px;margin:0">📈</p><p style="font-size:12px;font-weight:600;margin:4px 0 0">Growth</p></div>
            <div style="border:1px solid #e5e7eb;border-radius:8px;padding:12px;text-align:center"><p style="font-size:20px;margin:0">🎯</p><p style="font-size:12px;font-weight:600;margin:4px 0 0">Strategy</p></div>
            <div style="border:1px solid #e5e7eb;border-radius:8px;padding:12px;text-align:center"><p style="font-size:20px;margin:0">🤝</p><p style="font-size:12px;font-weight:600;margin:4px 0 0">Advisory</p></div>
          </div>
        </div>`,
    },
    restaurant: {
      url: "https://bellavista-bistro.com",
      html: `
        <div style="font-family:system-ui,sans-serif">
          <div style="background:#1c1917;color:#fafaf9;padding:24px;border-radius:12px;text-align:center">
            <p style="font-size:11px;color:#a8a29e;margin:0 0 8px">FINE DINING</p>
            <h3 style="font-size:22px;font-weight:800;margin:0">Bella Vista Bistro</h3>
            <p style="font-size:13px;margin:12px 0 0;color:#d6d3d1">Farm-to-table cuisine in the heart of the city</p>
            <button style="margin-top:16px;background:#f59e0b;color:#1c1917;border:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:13px">Reserve a Table</button>
          </div>
          <div style="display:flex;gap:12px;margin-top:16px">
            <div style="flex:1;border:1px solid #e5e7eb;border-radius:8px;padding:12px"><p style="font-size:12px;font-weight:600;margin:0">🍝 Menu</p><p style="font-size:11px;color:#6b7280;margin:4px 0 0">Seasonal dishes</p></div>
            <div style="flex:1;border:1px solid #e5e7eb;border-radius:8px;padding:12px"><p style="font-size:12px;font-weight:600;margin:0">📍 Location</p><p style="font-size:11px;color:#6b7280;margin:4px 0 0">Open daily 11am–11pm</p></div>
          </div>
        </div>`,
    },
    saas: {
      url: "https://cloudpulse.io",
      html: `
        <div style="font-family:system-ui,sans-serif">
          <div style="background:linear-gradient(135deg,#4f46e5,#7c3aed);color:white;padding:24px;border-radius:12px">
            <p style="font-size:11px;opacity:0.8;margin:0 0 8px">B2B SAAS PLATFORM</p>
            <h3 style="font-size:22px;font-weight:800;margin:0">CloudPulse</h3>
            <p style="font-size:13px;margin:12px 0 0;opacity:0.9">Real-time analytics for modern teams</p>
            <div style="display:flex;gap:8px;margin-top:16px">
              <button style="background:white;color:#4f46e5;border:none;padding:10px 16px;border-radius:8px;font-weight:600;font-size:12px">Start Free Trial</button>
              <button style="background:transparent;color:white;border:1px solid rgba(255,255,255,0.4);padding:10px 16px;border-radius:8px;font-weight:600;font-size:12px">Watch Demo</button>
            </div>
          </div>
          <div style="margin-top:16px;border:1px solid #e5e7eb;border-radius:8px;padding:12px">
            <p style="font-size:12px;font-weight:600;margin:0 0 8px">Trusted by 500+ teams</p>
            <div style="display:flex;gap:16px"><span style="font-size:11px;color:#6b7280">⚡ 99.9% uptime</span><span style="font-size:11px;color:#6b7280">🔒 SOC2 ready</span><span style="font-size:11px;color:#6b7280">📊 Live dashboards</span></div>
          </div>
        </div>`,
    },
    retail: {
      url: "https://urbanstyle-shop.com",
      html: `
        <div style="font-family:system-ui,sans-serif">
          <div style="background:#fdf2f8;padding:24px;border-radius:12px;text-align:center;border:1px solid #fbcfe8">
            <p style="font-size:11px;color:#be185d;margin:0 0 8px">NEW COLLECTION 2026</p>
            <h3 style="font-size:22px;font-weight:800;margin:0;color:#831843">Urban Style Co.</h3>
            <p style="font-size:13px;margin:12px 0 0;color:#9d174d">Premium fashion, delivered to your door</p>
            <button style="margin-top:16px;background:#be185d;color:white;border:none;padding:10px 20px;border-radius:8px;font-weight:600;font-size:13px">Shop Now — 20% Off</button>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:16px">
            <div style="background:#f9fafb;border-radius:8px;padding:16px;text-align:center"><p style="font-size:24px;margin:0">👗</p><p style="font-size:11px;font-weight:600;margin:4px 0 0">Women</p></div>
            <div style="background:#f9fafb;border-radius:8px;padding:16px;text-align:center"><p style="font-size:24px;margin:0">👔</p><p style="font-size:11px;font-weight:600;margin:4px 0 0">Men</p></div>
          </div>
        </div>`,
    },
  };

  let selected = "";
  const generateBtn = document.getElementById("generate-website") as HTMLButtonElement;
  const loader = document.getElementById("website-loader")!;
  const previewWrap = document.getElementById("website-preview-wrap")!;
  const preview = document.getElementById("website-preview")!;
  const urlEl = document.getElementById("website-url")!;

  document.querySelectorAll(".industry-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".industry-btn").forEach((b) => {
        b.classList.remove("ring-2", "ring-emerald-500");
      });
      btn.classList.add("ring-2", "ring-emerald-500");
      selected = (btn as HTMLElement).dataset.industry!;
      generateBtn.disabled = false;
    });
  });

  generateBtn?.addEventListener("click", () => {
    if (!selected) return;
    loader.classList.remove("hidden");
    previewWrap.classList.add("hidden");

    setTimeout(() => {
      loader.classList.add("hidden");
      const data = PREVIEWS[selected];
      urlEl.textContent = data.url;
      preview.innerHTML = data.html;
      previewWrap.classList.remove("hidden");
    }, 1500);
  });
</script>
