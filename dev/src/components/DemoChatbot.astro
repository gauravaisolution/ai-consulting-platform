<section class="py-4" id="demo-chatbot">
  <div>
    <div class="mb-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-violet-600 dark:text-violet-400">
        Live Demo D
      </p>
      <h2 class="mt-2 text-3xl font-bold">AI Website Chatbot</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        See how an AI chatbot handles customer questions on your business website — 24/7.
      </p>
    </div>

    <div
      class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900"
    >
      <div
        class="mx-auto max-w-md overflow-hidden rounded-2xl border border-gray-200 shadow-lg dark:border-gray-700"
      >
        <div class="flex items-center gap-3 bg-violet-600 px-4 py-3 text-white">
          <div
            class="flex h-8 w-8 items-center justify-center rounded-full bg-white/20 text-sm font-bold"
          >
            AI
          </div>
          <div>
            <p class="text-sm font-semibold">FutureStack Assistant</p>
            <p class="text-xs text-violet-200">Online · Typically replies instantly</p>
          </div>
        </div>

        <div
          id="chat-messages"
          class="flex h-72 flex-col gap-3 overflow-y-auto bg-gray-50 p-4 dark:bg-gray-900"
        >
          <div class="max-w-[85%] rounded-2xl rounded-bl-sm bg-white px-4 py-2 text-sm shadow-sm dark:bg-gray-800">
            Hi! 👋 I'm the AI assistant for this business. How can I help you today?
          </div>
        </div>

        <div class="border-t border-gray-200 bg-white p-3 dark:border-gray-700 dark:bg-gray-900">
          <div class="mb-2 flex flex-wrap gap-1.5">
            <button
              type="button"
              data-msg="hours"
              class="chat-preset rounded-full bg-violet-100 px-3 py-1 text-xs font-medium text-violet-700 dark:bg-violet-900/50 dark:text-violet-300"
            >
              What are your hours?
            </button>
            <button
              type="button"
              data-msg="pricing"
              class="chat-preset rounded-full bg-violet-100 px-3 py-1 text-xs font-medium text-violet-700 dark:bg-violet-900/50 dark:text-violet-300"
            >
              Pricing info
            </button>
            <button
              type="button"
              data-msg="book"
              class="chat-preset rounded-full bg-violet-100 px-3 py-1 text-xs font-medium text-violet-700 dark:bg-violet-900/50 dark:text-violet-300"
            >
              Book a consultation
            </button>
          </div>
          <div class="flex gap-2">
            <input
              id="chat-input"
              type="text"
              placeholder="Type a message..."
              class="flex-1 rounded-xl border border-gray-300 bg-gray-50 px-3 py-2 text-sm outline-none focus:border-violet-500 dark:border-gray-700 dark:bg-gray-800"
            />
            <button
              id="chat-send"
              type="button"
              class="rounded-xl bg-violet-600 px-4 py-2 text-sm font-semibold text-white hover:bg-violet-700"
            >
              Send
            </button>
          </div>
        </div>
      </div>

      <div
        id="chat-locked"
        class="mt-4 hidden rounded-xl border border-amber-300 bg-amber-50 p-4 dark:border-amber-700 dark:bg-amber-900/30"
      >
        <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
          Custom chatbot flows are locked in the public sandbox.
        </p>
        <p class="mt-1 text-sm text-amber-700 dark:text-amber-300">
          Book a strategy call to connect a chatbot trained on your business data, products, and FAQs.
        </p>
        <a
          href="/contact"
          class="mt-3 inline-block text-sm font-semibold text-amber-900 underline dark:text-amber-100"
        >
          Book a strategy call →
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const REPLIES: Record<string, string> = {
    hours:
      "We're available Monday–Friday, 9am–6pm EST. For urgent matters, leave a message and we'll respond within 2 hours during business hours.",
    pricing:
      "Our website packages start at $1,500 and AI chatbot integrations from $800. Every project includes a free strategy call to scope your exact needs. Want me to book one for you?",
    book: "Great! I can help you schedule a free 30-minute strategy call. Head to our booking page — you'll pick a time that works for you. Shall I send the link?",
  };

  const USER_LABELS: Record<string, string> = {
    hours: "What are your hours?",
    pricing: "Pricing info",
    book: "Book a consultation",
  };

  const messages = document.getElementById("chat-messages")!;
  const input = document.getElementById("chat-input") as HTMLInputElement;
  const locked = document.getElementById("chat-locked")!;
  let typing = false;

  function addBubble(text: string, isUser: boolean) {
    const bubble = document.createElement("div");
    bubble.className = isUser
      ? "ml-auto max-w-[85%] rounded-2xl rounded-br-sm bg-violet-600 px-4 py-2 text-sm text-white"
      : "max-w-[85%] rounded-2xl rounded-bl-sm bg-white px-4 py-2 text-sm shadow-sm dark:bg-gray-800";
    bubble.textContent = text;
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
  }

  function botReply(key: string) {
    if (typing) return;
    typing = true;
    locked.classList.add("hidden");

    const reply = REPLIES[key];
    if (!reply) return;

    const typingEl = document.createElement("div");
    typingEl.className =
      "max-w-[85%] rounded-2xl rounded-bl-sm bg-white px-4 py-2 text-sm text-gray-400 shadow-sm dark:bg-gray-800";
    typingEl.textContent = "Typing...";
    messages.appendChild(typingEl);
    messages.scrollTop = messages.scrollHeight;

    setTimeout(() => {
      typingEl.remove();
      let i = 0;
      const bubble = document.createElement("div");
      bubble.className =
        "max-w-[85%] rounded-2xl rounded-bl-sm bg-white px-4 py-2 text-sm shadow-sm dark:bg-gray-800";
      messages.appendChild(bubble);

      const interval = setInterval(() => {
        if (i < reply.length) {
          bubble.textContent += reply[i++];
          messages.scrollTop = messages.scrollHeight;
        } else {
          clearInterval(interval);
          typing = false;
        }
      }, 20);
    }, 600);
  }

  function handlePreset(key: string) {
    addBubble(USER_LABELS[key], true);
    botReply(key);
  }

  document.querySelectorAll(".chat-preset").forEach((btn) => {
    btn.addEventListener("click", () => {
      handlePreset((btn as HTMLElement).dataset.msg!);
    });
  });

  function handleSend() {
    const text = input.value.trim();
    if (!text || typing) return;
    input.value = "";
    addBubble(text, true);

    const lower = text.toLowerCase();
    if (lower.includes("hour") || lower.includes("open")) handlePreset("hours");
    else if (lower.includes("pric") || lower.includes("cost")) handlePreset("pricing");
    else if (lower.includes("book") || lower.includes("call") || lower.includes("consult"))
      handlePreset("book");
    else {
      locked.classList.remove("hidden");
      const bubble = document.createElement("div");
      bubble.className =
        "max-w-[85%] rounded-2xl rounded-bl-sm bg-white px-4 py-2 text-sm text-gray-500 shadow-sm dark:bg-gray-800";
      bubble.textContent =
        "I'd need to be connected to your business data to answer that. Try a preset question above!";
      messages.appendChild(bubble);
      messages.scrollTop = messages.scrollHeight;
    }
  }

  document.getElementById("chat-send")?.addEventListener("click", handleSend);
  input?.addEventListener("keydown", (e) => {
    if (e.key === "Enter") {
      e.preventDefault();
      handleSend();
    }
  });
</script>
