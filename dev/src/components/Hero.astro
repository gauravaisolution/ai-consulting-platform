---
import { site } from "../site.config";
import HeroVisual from "./HeroVisual.astro";
---

<section class="relative overflow-hidden px-6 py-20 md:py-28">
  <!-- Animated gradient orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="animate-float absolute -top-32 -right-32 h-96 w-96 rounded-full bg-blue-400/20 blur-3xl dark:bg-blue-600/10"
    >
    </div>
    <div
      class="animate-float-delayed absolute -bottom-32 -left-32 h-96 w-96 rounded-full bg-indigo-400/20 blur-3xl dark:bg-indigo-600/10"
    >
    </div>
    <div
      class="animate-pulse-glow absolute top-1/2 left-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-violet-400/10 blur-3xl"
    >
    </div>
  </div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2 lg:gap-16">
    <div class="text-center lg:text-left">
      <p
        class="mb-4 inline-block rounded-full border border-blue-200 bg-blue-50 px-4 py-1 text-sm font-medium text-blue-700 dark:border-blue-800 dark:bg-blue-950/50 dark:text-blue-300"
      >
        Data & AI Solutions
      </p>
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl lg:text-6xl dark:text-white"
      >
        Build your <span class="bg-gradient-to-r from-blue-600 to-indigo-500 bg-clip-text text-transparent">digital presence</span> with AI that works
      </h1>
      <p class="mx-auto mt-6 max-w-xl text-lg text-gray-600 lg:mx-0 dark:text-gray-300">
        {site.tagline}. We build business websites, integrate AI chatbots, and deploy data systems —
        so you can focus on growth.
      </p>
      <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row lg:justify-start">
        <a
          href="/contact"
          class="btn-glow w-full rounded-xl bg-blue-600 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-blue-600/25 sm:w-auto"
        >
          Book a Strategy Call
        </a>
        <a
          href="#demos"
          class="w-full rounded-xl border border-gray-300 px-8 py-3.5 text-base font-semibold text-gray-700 transition hover:bg-gray-50 sm:w-auto dark:border-gray-700 dark:text-gray-200 dark:hover:bg-gray-900"
        >
          Try Live Demos
        </a>
      </div>
    </div>

    <div class="reveal flex justify-center lg:justify-end">
      <HeroVisual />
    </div>
  </div>
</section>
