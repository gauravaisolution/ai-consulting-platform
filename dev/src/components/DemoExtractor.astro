<section class="py-4" id="demo-extractor">
  <div>
    <div class="mb-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400">
        Live Demo A
      </p>
      <h2 class="mt-2 text-3xl font-bold">Intelligent Data Extractor</h2>
      <p class="mt-3 text-gray-600 dark:text-gray-400">
        Upload a receipt file — watch our OCR pipeline extract structured data in real time.
      </p>
    </div>

    <div
      class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm dark:border-gray-800 dark:bg-gray-900"
    >
      <label
        for="receipt-upload"
        class="flex cursor-pointer flex-col items-center rounded-xl border-2 border-dashed border-gray-300 px-6 py-12 transition hover:border-blue-400 hover:bg-blue-50/50 dark:border-gray-700 dark:hover:border-blue-500 dark:hover:bg-blue-950/20"
      >
        <span class="text-4xl">📄</span>
        <span class="mt-3 text-sm font-medium text-gray-700 dark:text-gray-300">
          Click to upload a receipt (PDF, PNG, JPG)
        </span>
        <span class="mt-1 text-xs text-gray-500">Try: receipt_acme.pdf or invoice_cloudco.png</span>
        <input id="receipt-upload" type="file" accept=".pdf,.png,.jpg,.jpeg" class="hidden" />
      </label>

      <div id="extractor-loader" class="mt-6 hidden text-center">
        <div
          class="mx-auto h-10 w-10 animate-spin-slow rounded-full border-4 border-blue-200 border-t-blue-600"
        >
        </div>
        <p class="mt-4 text-sm font-medium text-gray-600 dark:text-gray-400">
          Running OCR pipeline...
        </p>
        <div class="mt-2 flex justify-center gap-1">
          <span class="h-2 w-2 animate-pulse-dot rounded-full bg-blue-600"></span>
          <span
            class="h-2 w-2 animate-pulse-dot rounded-full bg-blue-600"
            style="animation-delay: 0.2s"></span>
          <span
            class="h-2 w-2 animate-pulse-dot rounded-full bg-blue-600"
            style="animation-delay: 0.4s"></span>
        </div>
      </div>

      <div id="extractor-result" class="mt-6 hidden">
        <p class="mb-3 text-sm font-semibold text-green-600 dark:text-green-400">
          ✓ Extraction complete
        </p>
        <pre
          id="extractor-json"
          class="overflow-x-auto rounded-xl bg-gray-950 p-6 text-sm leading-relaxed text-green-400"
        ></pre>
      </div>

      <div id="extractor-error" class="mt-6 hidden rounded-xl bg-amber-50 p-4 text-sm text-amber-800 dark:bg-amber-900/30 dark:text-amber-200">
      </div>
    </div>
  </div>
</section>

<script>
  const KNOWN_FILES: Record<string, object> = {
    "receipt_acme.pdf": {
      vendor: "Acme Corp",
      date: "2026-05-14",
      currency: "USD",
      line_items: [
        { description: "Cloud Storage (500GB)", amount: 120.0 },
        { description: "API Calls (2.1M)", amount: 45.5 },
        { description: "Support Plan — Pro", amount: 99.0 },
      ],
      subtotal: 264.5,
      tax: 21.16,
      total: 285.66,
    },
    "invoice_cloudco.png": {
      vendor: "CloudCo Industries",
      date: "2026-05-22",
      currency: "USD",
      line_items: [
        { description: "Compute Instances (4x)", amount: 340.0 },
        { description: "Data Transfer", amount: 28.75 },
        { description: "Load Balancer", amount: 55.0 },
      ],
      subtotal: 423.75,
      tax: 33.9,
      total: 457.65,
    },
    "receipt_starbucks.jpg": {
      vendor: "Starbucks — Downtown",
      date: "2026-06-01",
      currency: "USD",
      line_items: [
        { description: "Latte Grande", amount: 5.45 },
        { description: "Croissant", amount: 3.95 },
      ],
      subtotal: 9.4,
      tax: 0.75,
      total: 10.15,
    },
  };

  const upload = document.getElementById("receipt-upload") as HTMLInputElement;
  const loader = document.getElementById("extractor-loader")!;
  const result = document.getElementById("extractor-result")!;
  const jsonEl = document.getElementById("extractor-json")!;
  const errorEl = document.getElementById("extractor-error")!;

  upload?.addEventListener("change", (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;

    loader.classList.remove("hidden");
    result.classList.add("hidden");
    errorEl.classList.add("hidden");

    setTimeout(() => {
      loader.classList.add("hidden");
      const data = KNOWN_FILES[file.name.toLowerCase()];

      if (data) {
        jsonEl.textContent = JSON.stringify(data, null, 2);
        result.classList.remove("hidden");
      } else {
        errorEl.textContent = `Demo file "${file.name}" not in sandbox. Try: receipt_acme.pdf, invoice_cloudco.png, or receipt_starbucks.jpg — or book a call to connect your real documents.`;
        errorEl.classList.remove("hidden");
      }
    }, 1500);
  });
</script>
