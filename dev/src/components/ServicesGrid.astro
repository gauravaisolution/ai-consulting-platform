---
import { services } from "../site.config";
import ServiceIcon from "./ServiceIcon.astro";
---

<section class="reveal px-6 py-20">
  <div class="mx-auto max-w-6xl">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">What we build</h2>
      <p class="mx-auto mt-4 max-w-2xl text-gray-600 dark:text-gray-400">
        Websites, chatbots, and intelligent data systems — built end-to-end.
      </p>
    </div>
    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <div class="glass-card hover-lift rounded-2xl p-8">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-blue-100 text-blue-600 dark:bg-blue-900/40 dark:text-blue-400">
              <ServiceIcon name={service.icon} class="h-6 w-6" />
            </div>
            <h3 class="mt-5 text-xl font-semibold">{service.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600 dark:text-gray-400">
              {service.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
