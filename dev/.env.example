# Site Configuration
# Copy this file to .env and fill in your values
# These are injected at build time (Astro static site)

# Business Info
PUBLIC_SITE_NAME="Your Company Name"
PUBLIC_SITE_TAGLINE="Your tagline here"
PUBLIC_SITE_DESCRIPTION="Your site description for SEO and meta tags"
PUBLIC_SITE_EMAIL="hello@example.com"

# Integrations
PUBLIC_TALLY_FORM_URL="https://tally.so/embed/YOUR_FORM_ID"
PUBLIC_CALCOM_URL="https://cal.com/your-username/meeting-type?embed=true"
